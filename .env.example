# CloudLearn — docker-compose environment overrides.
# Copy to `.env` and edit; `.env` is already in .gitignore.
#
# Quick start: this file ships with sensible dev defaults — `docker compose up -d`
# will work without any changes.

# ── Simulator ─────────────────────────────────────────────────────────────
# Image source. Leave default to pull the published image from Docker Hub.
# Set to empty string to build locally from Dockerfile in the repo.
CLOUDLEARN_SIMULATOR_IMAGE=cloudlearn/simulator:1.0.0

# Host port for the simulator (default 9000)
CLOUDLEARN_SIMULATOR_PORT=9000

# Pre-seed a license tier (free | student | developer | enterprise).
# Leave unset to start on Free tier (default).
# CLOUDLEARN_LICENSE_TIER=enterprise

# Disable the host-budget gate (allows large VMs in dev/test environments).
# CLOUDLEARN_BUDGET_BYPASS=1

# ── Backend credentials (production: change these!) ───────────────────────
# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cloudlearn

# MySQL
MYSQL_ROOT_PASSWORD=cloudlearn

# MinIO (S3-compatible)
MINIO_ROOT_USER=cloudlearn
MINIO_ROOT_PASSWORD=cloudlearn-dev-secret-key

# Vault root token (DEV ONLY — production uses file backend + init/unseal;
# see docs/PRODUCTION_DEPLOYMENT.md)
CLOUDLEARN_VAULT_TOKEN=cloudlearn-dev-token

# ── Distribution mode ─────────────────────────────────────────────────────
# Override only if you know what you're doing.
# CLOUDLEARN_DISTRIBUTION_MODE=developer
# CLOUDLEARN_PARENT_OS=linux
# CLOUDLEARN_RUNTIME_BRIDGE_URL=http://host.docker.internal:9171
