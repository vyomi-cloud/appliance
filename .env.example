# Vyomi — docker-compose environment overrides.
# Copy to `.env` and edit; `.env` is already in .gitignore.
#
# Quick start: this file ships with sensible dev defaults — `docker compose up -d`
# will work without any changes.
#
# ─── Env var naming ─────────────────────────────────────────────────────
# Canonical names use the `VYOMI_*` prefix (v2.0.0+). The legacy
# `CLOUDLEARN_*` prefix continues to work — the appliance runs a runtime
# mirror that bridges both spellings at startup (see core/env_aliases.py).
# Legacy support slated for removal in v3.0.

# ── Simulator + CloudSim images ───────────────────────────────────────────
# Published multi-arch (amd64+arm64) on Docker Hub + GHCR. By DEFAULT the
# compose files resolve these to `:latest`, so a fresh `docker compose pull`
# always gets the current release — and this file stays correct even when it's
# copied from an old git tag (the previous hard-pin silently shipped a stale
# version to anyone curl-ing it from a tag). To PIN specific versions for
# reproducible installs, uncomment + set explicit tags below. Leave them
# commented to build locally from source instead (dev clone).
# VYOMI_SIMULATOR_IMAGE=vyomi/appliance:2.0.8
# VYOMI_CLOUDSIM_IMAGE=vyomi/cloudsim:2.0.8

# Host port for the simulator (default 9000)
VYOMI_SIMULATOR_PORT=9000

# Pre-seed a license tier (free | pro | max | enterprise).
# Leave unset to start on Free tier (default).
# VYOMI_LICENSE_TIER=enterprise

# Disable the host-budget gate (allows large VMs in dev/test environments).
# VYOMI_BUDGET_BYPASS=1

# ── Backend credentials (production: change these!) ───────────────────────
# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cloudlearn

# MySQL
MYSQL_ROOT_PASSWORD=cloudlearn

# MinIO (S3-compatible)
MINIO_ROOT_USER=cloudlearn
MINIO_ROOT_PASSWORD=cloudlearn-dev-secret-key

# Vault root token (DEV ONLY — production uses file backend + init/unseal;
# see docs/PRODUCTION_DEPLOYMENT.md)
VYOMI_VAULT_TOKEN=cloudlearn-dev-token

# ── Distribution mode ─────────────────────────────────────────────────────
# Override only if you know what you're doing.
# VYOMI_DISTRIBUTION_MODE=developer
# VYOMI_PARENT_OS=linux
# VYOMI_RUNTIME_BRIDGE_URL=http://host.docker.internal:9171
