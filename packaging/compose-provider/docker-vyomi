#!/usr/bin/env bash
# docker-vyomi — Docker Compose *provider* plugin.
#
# Makes `docker compose up` a familiar front door to the host `vyomi up`
# launcher. docker-compose is an *assisting tool*, never an installer — the
# appliance always boots inside Multipass (the appliance boundary), where
# EC2/LXD compute, networking, TLS and storage all work consistently.
#
# Compose invokes this binary (it runs on the HOST, not in a container):
#   docker-vyomi compose --project-name <P> up   [--opt=val ...] <SERVICE>
#   docker-vyomi compose --project-name <P> down  <SERVICE>
#   docker-vyomi compose --project-name <P> stop  <SERVICE>
#
# Protocol: write JSON lines to stdout — {"type":"info|error|setenv|debug","message":"..."}
# Exit 0 on success; non-zero makes Compose report the error.
#
# Test/plumbing mode: set VYOMI_PROVIDER_DRYRUN=1 to print what it WOULD run
# without booting Multipass (used to validate the Compose↔plugin wiring).
set -euo pipefail

emit() { printf '{"type":"%s","message":"%s"}\n' "$1" "$2"; }

# ── Docker CLI plugin handshake (so `docker` lists it cleanly) ───────────
if [ "${1:-}" = "docker-cli-plugin-metadata" ]; then
  printf '{"SchemaVersion":"0.1.0","Vendor":"Vyomi","Version":"%s","ShortDescription":"Compose provider — boots the Vyomi appliance via vyomi up (Multipass)"}\n' \
    "${VYOMI_PROVIDER_VERSION:-2.0.9.2}"
  exit 0
fi

# ── Compose provider protocol ────────────────────────────────────────────
[ "${1:-}" = "compose" ] || { emit error "unsupported invocation: $*"; exit 1; }
shift

PROJECT=""
ACTION=""
while [ $# -gt 0 ]; do
  case "$1" in
    --project-name)   PROJECT="${2:-}"; shift 2 ;;
    --project-name=*) PROJECT="${1#*=}"; shift ;;
    up|down|stop)     ACTION="$1"; shift ;;
    *)                shift ;;   # ignore option flags + service name (PoC)
  esac
done

# Prefer the repo launcher (current source) if pointed at it; else installed `vyomi`.
LAUNCHER=""
if [ -n "${VYOMI_LAUNCHER:-}" ] && [ -x "${VYOMI_LAUNCHER}" ]; then
  LAUNCHER="${VYOMI_LAUNCHER}"
elif command -v vyomi >/dev/null 2>&1; then
  LAUNCHER="$(command -v vyomi)"
fi

run_launcher() {  # $1 = up|down|stop
  if [ "${VYOMI_PROVIDER_DRYRUN:-0}" = "1" ]; then
    emit info "[dry-run] would exec: ${LAUNCHER:-vyomi} $1"
    return 0
  fi
  [ -n "$LAUNCHER" ] || { emit error "vyomi launcher not found — install it: brew install vyomi-cloud/tap/vyomi"; exit 1; }
  "$LAUNCHER" "$1"
}

case "$ACTION" in
  up)
    emit info "Vyomi runs inside Multipass — the appliance boundary (project: ${PROJECT:-vyomi})."
    emit info "Routing 'docker compose up' to the host launcher: ${LAUNCHER:-vyomi} up"
    emit info "First run installs Multipass and boots the VM (~3-5 min); EC2/LXD compute works there."
    run_launcher up
    ;;
  down)
    emit info "Routing 'docker compose down' to: ${LAUNCHER:-vyomi} down"
    run_launcher down
    ;;
  stop)
    emit info "Routing 'docker compose stop' to: ${LAUNCHER:-vyomi} stop"
    run_launcher stop
    ;;
  *)
    emit error "unknown action: ${ACTION:-<none>}"; exit 1 ;;
esac
