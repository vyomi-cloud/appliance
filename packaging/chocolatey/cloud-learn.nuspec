<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>cloud-learn</id>
    <version>1.0.0</version>
    <title>CloudLearn</title>
    <authors>CloudLearn contributors</authors>
    <owners>CloudLearn</owners>
    <projectUrl>https://github.com/sudhirkumarganti/cloud-learn</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/sudhirkumarganti/cloud-learn/main/static/favicon.ico</iconUrl>
    <licenseUrl>https://github.com/sudhirkumarganti/cloud-learn/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <bugTrackerUrl>https://github.com/sudhirkumarganti/cloud-learn/issues</bugTrackerUrl>
    <docsUrl>https://github.com/sudhirkumarganti/cloud-learn/blob/main/README.md</docsUrl>
    <packageSourceUrl>https://github.com/sudhirkumarganti/cloud-learn/tree/main/packaging/chocolatey</packageSourceUrl>
    <description>
Local multi-cloud simulator (AWS/GCP/Azure) with real backends.

Standard provider SDKs (boto3, aws-sdk-java, google-cloud-*, azure-sdk-for-*)
and CLIs (aws, gcloud, gsutil, bq, az, terraform) work natively against the
simulator by overriding the endpoint URL — no shim required.

The package installs the launcher; the full simulator stack runs inside a
Multipass VM that `cloud-learn up` provisions.
    </description>
    <summary>Local multi-cloud simulator (AWS/GCP/Azure)</summary>
    <releaseNotes>https://github.com/sudhirkumarganti/cloud-learn/blob/main/docs/RELEASE_NOTES_v1.0.md</releaseNotes>
    <copyright>Copyright (c) 2026 CloudLearn contributors</copyright>
    <tags>cloud aws gcp azure simulator developer-tools multi-cloud testing localstack-alternative</tags>
    <dependencies>
      <dependency id="chocolatey-core.extension" version="1.4.0" />
    </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
