#!/usr/bin/env bash
# vyomi-docker — Docker-substrate launcher for the Free / Lite / Pro tiers.
#
# Runs the Vyomi simulator via `docker compose` using the pull-only
# docker-compose.cloudlite.yml shipped in this package. It NEVER installs or
# touches Multipass / LXD — that's the Max tier (the `cloud-learn`/`vyomi`
# launcher package). Compute (Pro) runs as sibling Docker containers.
#
# Usage:  vyomi up | down | restart | status | logs | update
set -euo pipefail

# Help works without Docker or the bundled compose file (used by the brew test).
case "${1:-up}" in
  -h|--help|help)
    echo "vyomi (Docker substrate) — Free/Lite/Pro tiers"
    echo "  vyomi up | down | restart | status | logs | update"
    echo "  Runs the simulator via 'docker compose up'; never touches Multipass."
    exit 0
    ;;
esac

# Find the bundled compose file. Works for both the .deb/.rpm layout
# (/usr/bin/vyomi + /usr/share/vyomi-docker/) and the Homebrew layout
# (PREFIX/bin/vyomi + PREFIX/share/vyomi-docker/), via a path relative to
# this script. Override with VYOMI_COMPOSE_FILE.
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE_FILE="${VYOMI_COMPOSE_FILE:-}"
if [ -z "$COMPOSE_FILE" ]; then
  for _c in "/usr/share/vyomi-docker/docker-compose.cloudlite.yml" \
            "$SELF_DIR/../share/vyomi-docker/docker-compose.cloudlite.yml"; do
    if [ -f "$_c" ]; then COMPOSE_FILE="$_c"; break; fi
  done
fi
if [ -z "$COMPOSE_FILE" ] || [ ! -f "$COMPOSE_FILE" ]; then
  echo "vyomi: bundled docker-compose.cloudlite.yml not found (set VYOMI_COMPOSE_FILE)." >&2
  exit 1
fi
PROJECT="${VYOMI_PROJECT:-vyomi}"

if ! command -v docker >/dev/null 2>&1; then
  echo "vyomi: Docker is required but was not found on PATH." >&2
  echo "  Install Docker Desktop (macOS/Windows) or Docker Engine (Linux):" >&2
  echo "    https://docs.docker.com/engine/install/" >&2
  exit 1
fi

# Prefer the Compose v2 plugin (`docker compose`); fall back to v1 binary.
if docker compose version >/dev/null 2>&1; then
  DC=(docker compose)
else
  DC=(docker-compose)
fi
dc() { "${DC[@]}" -f "$COMPOSE_FILE" -p "$PROJECT" "$@"; }

case "${1:-up}" in
  up|start)
    dc up -d
    echo "==> Vyomi (Docker) is starting. Open http://localhost:9000 in ~30s."
    echo "    Pro tier: launch an EC2 instance in the console, then ssh ubuntu@<ip>."
    ;;
  down|stop)       dc down ;;
  restart)         dc down; dc up -d ;;
  status|ps)       dc ps ;;
  logs)            shift; dc logs "$@" ;;
  update|upgrade)  dc pull && dc up -d ;;
  *)               dc "$@" ;;
esac
