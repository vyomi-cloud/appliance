#!/usr/bin/env bash
if [ -z "${BASH_VERSION:-}" ]; then
  if command -v bash >/dev/null 2>&1; then
    exec bash "$0" "$@"
  fi
  printf '%s\n' 'bash is required to run cloud-learn' >&2
  exit 1
fi

set -euo pipefail

SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="${CLOUD_LEARN_HOME:-$(cd "${SCRIPT_PATH}/.." && pwd)}"
PROJECT_NAME="${CLOUD_LEARN_PROJECT_NAME:-cloud-learn}"
RUNTIME_CONTEXT="${CLOUD_LEARN_RUNTIME_CONTEXT:-outer}"
COMPOSE_FILE="${CLOUD_LEARN_COMPOSE_FILE:-${ROOT_DIR}/docker-compose.appliance.yml}"
PARENT_OS="${CLOUD_LEARN_PARENT_OS:-$(uname -s)}"
DISTRIBUTION_MODE="appliance"
APPLIANCE_NAME="${CLOUD_LEARN_APPLIANCE_NAME:-cloudlearn-appliance}"
# APPLIANCE_DIR lives under the user's HOME by default — not the launcher's
# ROOT_DIR — so that when cloud-learn is installed via brew (ROOT_DIR is
# /opt/homebrew/Cellar/cloud-learn/<v>/libexec) the bootstrap artifacts
# (cloud-init.yaml, appliance-bootstrap.json, host-sizing-report.json) live
# in a path that:
#   1. is writeable by the launching user (brew's libexec is read-only on
#      stricter setups, and we don't want to mutate it anyway)
#   2. is reachable via `multipass transfer` (we don't need SSHFS access to
#      these files from inside the VM — SSHFS into brew-controlled paths
#      hits permission denials on macOS because the path is sandboxed)
# Per-VM subdir so multiple appliances on the same host don't collide.
APPLIANCE_DIR="${CLOUD_LEARN_APPLIANCE_DIR:-${HOME}/.cloud-learn/appliance/${APPLIANCE_NAME}}"
APPLIANCE_IMAGE="${CLOUD_LEARN_APPLIANCE_IMAGE:-24.04}"
APPLIANCE_CPUS="${CLOUD_LEARN_APPLIANCE_CPUS:-4}"
APPLIANCE_MEMORY="${CLOUD_LEARN_APPLIANCE_MEMORY:-8G}"
APPLIANCE_DISK="${CLOUD_LEARN_APPLIANCE_DISK:-32G}"
# Tier-aware disk sizing — if the user already has a license JWT on disk,
# bootstrap with the disk size their tier deserves instead of the 32G
# free-tier default. Paid users with bigger fleets shouldn't have to
# re-launch the VM to grow it; they get the right size from minute one.
#   Free       → 30 GB (1 small VM comfortably)
#   Student    → 60 GB
#   Developer  → 120 GB
#   Enterprise → 240 GB
# Override at any time with CLOUD_LEARN_APPLIANCE_DISK=NG.
_tier_appliance_disk_gb() {
  local jwt_dir="$HOME/.config/vyomi"
  [ -f "$jwt_dir/active.json" ] || { echo "30"; return; }
  local tier
  tier=$(python3 -c "
import json, sys
try:
    with open('$jwt_dir/active.json') as f:
        d = json.load(f)
    print((d.get('tier') or 'free').lower())
except Exception:
    print('free')
" 2>/dev/null)
  case "$tier" in
    enterprise) echo "240" ;;
    developer)  echo "120" ;;
    student)    echo "60"  ;;
    *)          echo "30"  ;;
  esac
}
if [ "$APPLIANCE_DISK" = "32G" ] && [ -z "${CLOUD_LEARN_APPLIANCE_DISK:-}" ]; then
  APPLIANCE_DISK="$(_tier_appliance_disk_gb)G"
fi
APPLIANCE_WORKSPACE="${CLOUD_LEARN_APPLIANCE_WORKSPACE:-/workspace/cloud-learn}"
HOST_SIZING_FILE_NAME="host-sizing-report.json"

case "$PARENT_OS" in
  Darwin) PARENT_OS="darwin" ;;
  Linux) PARENT_OS="linux" ;;
  MINGW*|MSYS*|CYGWIN*|Windows_NT) PARENT_OS="windows" ;;
esac
case "$RUNTIME_CONTEXT" in
  outer|inner) ;;
  *) RUNTIME_CONTEXT="outer" ;;
esac
export CLOUDLEARN_DISTRIBUTION_MODE="$DISTRIBUTION_MODE"
export CLOUDLEARN_RUNTIME_CONTEXT="$RUNTIME_CONTEXT"

usage() {
  cat <<'EOF'
Vyomi simulator launcher (cloud-learn CLI) — local multi-cloud appliance

Usage:
  cloud-learn up [-v|--verbose]
  cloud-learn down
  cloud-learn stop
  cloud-learn force-stop
  cloud-learn kill
  cloud-learn restart
  cloud-learn status
  cloud-learn doctor
  cloud-learn help

Flags:
  -v, --verbose      Stream raw cloud-init log lines + sub-step detail.
                     Useful during triage. Same effect as
                     CLOUD_LEARN_VERBOSE=1 in the environment.

Environment:
  CLOUD_LEARN_HOME         Root directory containing CloudLearn sources
  CLOUD_LEARN_VERBOSE      Set to 1 to emit extra progress detail
  CLOUD_LEARN_COMPOSE_FILE Alternate compose file path
  CLOUD_LEARN_PROJECT_NAME Compose project name (default: cloud-learn)
  CLOUD_LEARN_RUNTIME_CONTEXT outer=manage appliance VM, inner=start stack in VM
  CLOUD_LEARN_APPLIANCE_NAME Multipass appliance VM name (default: cloudlearn-appliance)
  CLOUD_LEARN_APPLIANCE_DIR Appliance bootstrap directory
  CLOUD_LEARN_APPLIANCE_IMAGE Multipass image tag for the appliance VM
  CLOUD_LEARN_APPLIANCE_CPUS Multipass CPU count for the appliance VM
  CLOUD_LEARN_APPLIANCE_MEMORY Multipass memory size for the appliance VM
  CLOUD_LEARN_APPLIANCE_DISK Multipass disk size for the appliance VM
  CLOUD_LEARN_APPLIANCE_WORKSPACE Workspace path mounted into the appliance VM

Default mode:
  The launcher starts a single Multipass VM appliance and then starts the
  full Vyomi stack inside that VM.
EOF
}

write_appliance_manifest() {
  mkdir -p "$APPLIANCE_DIR"
  if ! command -v python3 >/dev/null 2>&1; then
    printf '%s\n' 'python3 is required to write the appliance manifest' >&2
    return 1
  fi
  python3 - "$APPLIANCE_DIR/appliance-bootstrap.json" "$APPLIANCE_NAME" "$APPLIANCE_IMAGE" "$APPLIANCE_CPUS" "$APPLIANCE_MEMORY" "$APPLIANCE_DISK" "$APPLIANCE_WORKSPACE" "$PARENT_OS" "$DISTRIBUTION_MODE" <<'PY'
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

path, name, image, cpus, memory, disk, workspace, host_os, distribution_mode = sys.argv[1:10]
payload = {
    "name": name,
    "image": image,
    "cpus": int(cpus),
    "memory": memory,
    "disk": disk,
    "workspace": workspace,
    "host_os": host_os,
    "distribution_mode": distribution_mode,
    "created_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.000Z"),
}
Path(path).write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
PY
}

appliance_ssh_identity_public_key() {
  local private_key="${HOME}/.ssh/cloudlearn_multipass_ed25519"
  local public_key="${private_key}.pub"
  if [ ! -f "$private_key" ] || [ ! -f "$public_key" ]; then
    mkdir -p "$(dirname "$private_key")"
    if ! ssh-keygen -t ed25519 -N "" -f "$private_key" -C "cloudlearn" >/dev/null 2>&1; then
      return 1
    fi
  fi
  if [ -f "$public_key" ]; then
    cat "$public_key"
  fi
}

write_appliance_host_sizing() {
  mkdir -p "$APPLIANCE_DIR"
  if ! command -v python3 >/dev/null 2>&1; then
    printf '%s\n' 'python3 is required to write the host sizing manifest' >&2
    return 1
  fi
  python3 - "$APPLIANCE_DIR/$HOST_SIZING_FILE_NAME" "$ROOT_DIR" "$PARENT_OS" <<'PY'
import json
import os
import platform
import shutil
import socket
import subprocess
import sys
from pathlib import Path
from datetime import datetime, timezone

path, root_dir, host_os = sys.argv[1:4]
host_os = (host_os or platform.system()).strip().lower()

def gib(value):
    return round(float(value or 0) / (1024 ** 3), 1)

def memory_bytes():
    try:
        if host_os == "darwin":
            return int(subprocess.check_output(["sysctl", "-n", "hw.memsize"], text=True).strip())
        if host_os == "linux":
            with open("/proc/meminfo", "r", encoding="utf-8") as fh:
                for line in fh:
                    if line.startswith("MemTotal:"):
                        parts = line.split()
                        if len(parts) >= 2:
                            return int(parts[1]) * 1024
            try:
                return int(os.sysconf("SC_PAGE_SIZE")) * int(os.sysconf("SC_PHYS_PAGES"))
            except Exception:
                return 0
    except Exception:
        return 0
    return 0

def recommend(cpu_count, memory_gib, disk_total_gib, disk_free_gib):
    if memory_gib <= 4:
        appliance_memory = 2
        appliance_disk = 24
    elif memory_gib <= 8:
        appliance_memory = 4
        appliance_disk = 32
    elif memory_gib <= 16:
        appliance_memory = 8
        appliance_disk = 32
    elif memory_gib <= 32:
        appliance_memory = 12
        appliance_disk = 48
    elif memory_gib <= 64:
        appliance_memory = 16
        appliance_disk = 64
    else:
        appliance_memory = min(24, max(16, int(round(memory_gib * 0.25))))
        appliance_disk = min(96, max(64, int(round(disk_total_gib * 0.12)) if disk_total_gib else 64))
    appliance_cpu = max(1, min(max(cpu_count - 1, 1), int(round(appliance_memory / 2)) or 1))
    appliance_disk = int(min(max(appliance_disk, 24), max(24, int(round(disk_free_gib * 0.25)) or appliance_disk)))
    reserve = 1.5 if memory_gib <= 8 else 2.0 if memory_gib <= 16 else 2.5 if memory_gib <= 32 else 3.0
    available = max(0.0, float(appliance_memory) - reserve)
    return {
        "appliance": {
            "vcpus": appliance_cpu,
            "memory_gib": appliance_memory,
            "disk_gib": appliance_disk,
        },
        "lxd_budget": {
            "platform_reserve_gib": reserve,
            "small_instances": int(available // 0.5),
            "medium_instances": int(available // 1.0),
            "heavy_instances": int(available // 2.0),
        },
    }

cpu_count = os.cpu_count() or 1
disk_usage = shutil.disk_usage(root_dir)
mem_bytes = memory_bytes()
mem_gib = gib(mem_bytes)
disk_total_gib = gib(disk_usage.total)
disk_free_gib = gib(disk_usage.free)
network_interfaces = []
try:
    network_interfaces = [name for _, name in socket.if_nameindex() if str(name).strip()]
except Exception:
    network_interfaces = []

payload = {
    "source": "launcher",
    "host_os": host_os,
    "cpu_count": int(cpu_count),
    "memory_bytes": int(mem_bytes),
    "memory_gib": mem_gib,
    "disk_total_bytes": int(disk_usage.total),
    "disk_used_bytes": int(disk_usage.used),
    "disk_free_bytes": int(disk_usage.free),
    "disk_total_gib": disk_total_gib,
    "disk_free_gib": disk_free_gib,
    "network_interfaces": network_interfaces,
    "network_interface_count": len(network_interfaces),
    "recommended": recommend(int(cpu_count), mem_gib, disk_total_gib, disk_free_gib),
    "warnings": [
        "This host is small for a full appliance. Keep the VM at minimum size and avoid heavy sandboxes."
    ] if int(cpu_count) < 4 or mem_gib < 8 else [],
    "checked_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.000Z"),
}
Path(path).write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
PY
}

appliance_sync_workspace_into_vm() {
  # Replaces the legacy SSHFS workspace mount. We tar+gzip just the files
  # the appliance docker stack needs, `multipass transfer` the tarball
  # in, and untar at $APPLIANCE_WORKSPACE on the VM.
  #
  # Why: on macOS brew installs ROOT_DIR is /opt/homebrew/Cellar/
  # cloud-learn/<v>/libexec which sits behind the brew-prefix sandbox.
  # Multipass's SSHFS mount cannot read THROUGH that sandbox from inside
  # the VM — every file shows as "Permission denied", even to root. The
  # symptom users hit on v1.1.7: docker compose up reported
  # `open /workspace/cloud-learn/docker-compose.appliance.yml: permission denied`.
  #
  # Tar+transfer side-steps SSHFS entirely. ~3 MB gzipped, transfers in
  # 2-3s. Trade-off: live-edit on host doesn't auto-propagate to VM —
  # users must `cloud-learn restart` to re-sync. For the brew install
  # target (always a pinned snapshot anyway) this is exactly right.
  local compose
  compose="$(appliance_multipass_cmd)"
  progress "==> Appliance: packaging source for VM (no SSHFS dependency)"
  local tarball
  tarball="$(mktemp -t cloud-learn-src-XXXXXX.tgz)"
  # Minimal allowlist — everything docker-compose.appliance.yml and the
  # two Dockerfiles need at build/runtime. Skip noise.
  (
    cd "$ROOT_DIR" || exit 1
    tar czf "$tarball" \
      --exclude '__pycache__' \
      --exclude '*.pyc' \
      --exclude 'target' \
      --exclude 'dist' \
      --exclude '.git' \
      --exclude '*.log' \
      Dockerfile \
      docker-compose.appliance.yml \
      docker-compose.yml \
      server.py \
      requirements.txt \
      core providers packs static \
      cloudsim-backbone \
      2>/dev/null
  )
  local sz
  sz=$(du -h "$tarball" 2>/dev/null | awk '{print $1}')
  verbose "tarball: ${tarball} (${sz})"
  if ! "$compose" transfer "$tarball" "${APPLIANCE_NAME}:/tmp/cloud-learn-src.tgz" >/dev/null 2>&1; then
    rm -f "$tarball"
    _die "multipass transfer failed pushing source tarball to VM" \
"Verify the VM is running:
  multipass info $APPLIANCE_NAME
And free /tmp space inside the VM:
  multipass exec $APPLIANCE_NAME -- df -h /tmp"
  fi
  rm -f "$tarball"
  if ! "$compose" exec "$APPLIANCE_NAME" -- /bin/bash -lc "
    sudo mkdir -p ${APPLIANCE_WORKSPACE}
    sudo tar xzf /tmp/cloud-learn-src.tgz -C ${APPLIANCE_WORKSPACE}
    sudo chown -R ubuntu:ubuntu ${APPLIANCE_WORKSPACE}
    rm -f /tmp/cloud-learn-src.tgz
  " >/dev/null 2>&1; then
    _die "failed to untar source into VM at ${APPLIANCE_WORKSPACE}" \
"Inspect the VM:
  multipass exec $APPLIANCE_NAME -- ls -la ${APPLIANCE_WORKSPACE}
  multipass exec $APPLIANCE_NAME -- df -h ${APPLIANCE_WORKSPACE}"
  fi
  verbose "workspace synced to ${APPLIANCE_NAME}:${APPLIANCE_WORKSPACE} (${sz} extracted)"
}

appliance_sync_host_sizing_into_vm() {
  local compose
  compose="$(appliance_multipass_cmd)"
  local local_path="${APPLIANCE_DIR}/${HOST_SIZING_FILE_NAME}"
  progress "==> Appliance: syncing host sizing into VM-local storage"
  if [ ! -f "$local_path" ]; then
    progress "    (skipping — ${HOST_SIZING_FILE_NAME} not written yet)"
    return 0
  fi
  # Use `multipass transfer` to push the file from the host directly into
  # the VM's /tmp, then sudo-install it into /var/lib/cloudlearn. This
  # avoids depending on the SSHFS workspace mount being readable — which
  # fails on macOS when ROOT_DIR is inside the brew prefix because the
  # multipass SSHFS connection can't traverse /opt/homebrew sandbox
  # boundaries. APPLIANCE_DIR lives under $HOME by default → always
  # transferable.
  "$compose" transfer "$local_path" "${APPLIANCE_NAME}:/tmp/${HOST_SIZING_FILE_NAME}" >/dev/null 2>&1 || {
    progress "    (warning: could not transfer ${HOST_SIZING_FILE_NAME} to VM)"
    return 0
  }
  "$compose" exec "$APPLIANCE_NAME" -- /bin/bash -lc \
    "sudo mkdir -p /var/lib/cloudlearn && sudo install -m 644 '/tmp/${HOST_SIZING_FILE_NAME}' /var/lib/cloudlearn/${HOST_SIZING_FILE_NAME} && rm -f /tmp/${HOST_SIZING_FILE_NAME}" >/dev/null 2>&1 || {
    progress "    (warning: could not install ${HOST_SIZING_FILE_NAME} on VM — continuing)"
    return 0
  }
}

write_appliance_cloud_init() {
  mkdir -p "$APPLIANCE_DIR"
  local public_key
  public_key="$(appliance_ssh_identity_public_key 2>/dev/null || true)"
  cat > "$APPLIANCE_DIR/cloud-init.yaml" <<EOF
#cloud-config
package_update: true
package_upgrade: true
$(if [ -n "$public_key" ]; then printf 'ssh_authorized_keys:\n  - %s\n' "$public_key"; fi)
packages:
  - python3
  - python3-pip
  - curl
  - ca-certificates
  - docker.io
  - docker-compose-v2
runcmd:
  - [ bash, -lc, "systemctl enable --now docker" ]
  - [ bash, -lc, "usermod -aG docker ubuntu || true" ]
  - [ bash, -lc, "update-alternatives --set docker-compose /usr/libexec/docker/cli-plugins/docker-compose || true" ]
  - [ bash, -lc, "snap install lxd || true" ]
  - [ bash, -lc, "usermod -aG lxd ubuntu || true" ]
  - [ bash, -lc, "cat >/tmp/cloudlearn-lxd-preseed.yaml <<'EOF'\nconfig: {}\nnetworks:\n- name: lxdbr0\n  type: bridge\n  config:\n    ipv4.address: auto\n    ipv4.nat: \"true\"\n    ipv6.address: auto\n    ipv6.nat: \"true\"\nstorage_pools:\n- name: default\n  driver: dir\nprofiles:\n- name: default\n  description: Default LXD profile\n  config: {}\n  devices:\n    root:\n      type: disk\n      pool: default\n      path: /\n    eth0:\n      type: nic\n      network: lxdbr0\n      name: eth0\nEOF\nlxd init --preseed < /tmp/cloudlearn-lxd-preseed.yaml || true" ]
  - [ bash, -lc, "mkdir -p ${APPLIANCE_WORKSPACE}" ]
  - [ bash, -lc, "sudo mkdir -p /var/lib/cloudlearn/deployments && sudo chown -R 100:101 /var/lib/cloudlearn/deployments" ]
EOF
}

# ── Launcher UX framework ──────────────────────────────────────────────
#
# Goals (we're building a commercial appliance):
#   1. Every run is logged to disk — when something fails the user has
#      a path to send us.
#   2. Phase counter `[3/7]` so the user knows where they are.
#   3. The launcher NEVER exits silently. On any non-zero exit, a clear
#      red FAILURE banner prints with: which phase, last log lines,
#      and copy-paste recovery commands.
#   4. On success, a green BANNER with the URL the user opens.
#   5. Verbose mode for triage (CLOUD_LEARN_VERBOSE=1 or -v).

# Global wall-clock anchor — set once at script start.
_LAUNCH_STARTED_AT="${_LAUNCH_STARTED_AT:-$(date +%s)}"
_PHASE_NUM=0
_PHASE_TOTAL=8
_PHASE_NAME=""
_PHASE_STARTED_AT=$_LAUNCH_STARTED_AT

# Persistent log under $HOME so the user always knows where to look
# even if the brew bundle gets reinstalled. Keep last 10.
_LOG_DIR="${HOME}/.cloud-learn/logs"
_LOG_FILE="${_LOG_DIR}/up-$(date +%Y%m%d-%H%M%S).log"
mkdir -p "$_LOG_DIR" 2>/dev/null || true
# Prune to last 10
ls -t "$_LOG_DIR"/up-*.log 2>/dev/null | tail -n +11 | xargs -r rm -f 2>/dev/null || true

# ANSI colours — disabled when not a TTY (so CI logs stay clean).
# IMPORTANT: use $'…' quoting so the backslash escapes resolve to real
# ESC bytes at variable-definition time. Plain single quotes preserve
# the literal text "\033[32m" which then prints as "\033[32m" instead
# of a real green colour.
if [ -t 2 ]; then
  _C_RESET=$'\033[0m'  _C_BOLD=$'\033[1m'  _C_DIM=$'\033[2m'
  _C_GREEN=$'\033[32m' _C_YELLOW=$'\033[33m' _C_RED=$'\033[31m' _C_CYAN=$'\033[36m'
else
  _C_RESET=''  _C_BOLD=''  _C_DIM=''
  _C_GREEN='' _C_YELLOW='' _C_RED='' _C_CYAN=''
fi

VERBOSE="${CLOUD_LEARN_VERBOSE:-0}"

# _emit prints to stderr (TTY) AND appends to the persistent log.
# Pass ALREADY-FORMATTED strings — _emit does not interpret %b or any
# format specifier. ANSI escapes in the string are preserved on TTY
# and stripped from the log via sed.
_emit() {
  local line="$1"
  printf '%s\n' "$line" >&2
  printf '%s\n' "${line}" | sed 's/\x1b\[[0-9;]*m//g' >> "$_LOG_FILE" 2>/dev/null || true
}

_ts_prefix() {
  local elapsed=$(( $(date +%s) - _LAUNCH_STARTED_AT ))
  printf '[%dm%02ds]' $(( elapsed / 60 )) $(( elapsed % 60 ))
}

progress() {
  _emit "$(_ts_prefix) $*"
}

verbose() {
  [ "$VERBOSE" = "0" ] && return 0
  _emit "$(_ts_prefix)   ${_C_DIM}·${_C_RESET} $*"
}

# phase() prints a numbered banner heading. Use at the start of each
# top-level step in cmd_up. Increments the global counter.
phase() {
  _PHASE_NUM=$(( _PHASE_NUM + 1 ))
  _PHASE_NAME="$1"
  _PHASE_STARTED_AT=$(date +%s)
  _emit "$(_ts_prefix) ${_C_CYAN}[${_PHASE_NUM}/${_PHASE_TOTAL}]${_C_RESET} ${_C_BOLD}${1}${_C_RESET}"
}

# phase_done() prints "✓ done in Xs" line. Call after each phase succeeds.
phase_done() {
  local elapsed_phase=$(( $(date +%s) - _PHASE_STARTED_AT ))
  _emit "$(_ts_prefix)       ${_C_GREEN}✓${_C_RESET} done in ${elapsed_phase}s"
}

# _die() — failure exit with a loud banner.
# Args: $1 = short description of what failed, $2 = recovery hint(s).
_die() {
  local what="$1"
  local hint="${2:-}"
  local elapsed_total=$(( $(date +%s) - _LAUNCH_STARTED_AT ))
  local m=$(( elapsed_total / 60 )) s=$(( elapsed_total % 60 ))
  _DIE_CALLED=1
  local bar="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  _emit ""
  _emit "${_C_RED}${bar}${_C_RESET}"
  _emit "${_C_BOLD}${_C_RED}✗ APPLIANCE LAUNCH FAILED${_C_RESET} after ${m}m$(printf '%02d' "$s")s"
  _emit "${_C_RED}${bar}${_C_RESET}"
  _emit ""
  _emit "  Failed at: ${_C_BOLD}Phase ${_PHASE_NUM}/${_PHASE_TOTAL} — ${_PHASE_NAME}${_C_RESET}"
  _emit "  Reason:    ${_C_YELLOW}${what}${_C_RESET}"
  if [ -n "$hint" ]; then
    _emit ""
    _emit "  ${_C_BOLD}What to try:${_C_RESET}"
    while IFS= read -r line; do _emit "    ${line}"; done <<<"$hint"
  fi
  _emit ""
  _emit "  Full log:  ${_LOG_FILE}"
  _emit "  Diagnose:  cloud-learn doctor"
  _emit ""
  exit 1
}

# Top-level ERR trap — fires on any uncaught non-zero exit. Even if a
# specific phase forgot to call _die(), the user still sees a banner
# instead of just a returned shell prompt.
on_err() {
  local rc=$?
  # Skip benign exits (already handled by _die or returned through normal flow).
  [ "$rc" -eq 0 ] && return 0
  if [ "${_DIE_CALLED:-0}" = "1" ]; then return 0; fi
  _die "command exited $rc inside Phase ${_PHASE_NUM}/${_PHASE_TOTAL} — ${_PHASE_NAME:-pre-flight}" \
"Re-run with verbose output:
  cloud-learn up -v
Inspect the persistent log:
  tail -n 80 ${_LOG_FILE}
Check the VM directly:
  multipass info ${APPLIANCE_NAME:-cloudlearn-appliance}
  multipass exec ${APPLIANCE_NAME:-cloudlearn-appliance} -- sudo journalctl -xb --no-pager | tail -50"
}
trap 'on_err' ERR

# Success banner — printed by cmd_up at the very end after health check.
launch_success_banner() {
  local url="$1"
  local elapsed_total=$(( $(date +%s) - _LAUNCH_STARTED_AT ))
  local m=$(( elapsed_total / 60 )) s=$(( elapsed_total % 60 ))
  local bar="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  _emit ""
  _emit "${_C_GREEN}${bar}${_C_RESET}"
  _emit "${_C_BOLD}${_C_GREEN}✓ APPLIANCE READY${_C_RESET} in ${m}m$(printf '%02d' "$s")s"
  _emit "${_C_GREEN}${bar}${_C_RESET}"
  _emit ""
  _emit "  Open in browser:  ${_C_BOLD}${_C_CYAN}${url}${_C_RESET}"
  _emit "  Log:              ${_LOG_FILE}"
  _emit ""
  _emit "  Stop:    cloud-learn stop"
  _emit "  Status:  cloud-learn status"
  _emit ""
}

# Human-readable description of a runcmd / install command, so the
# cloud-init poll can print "(installing LXD container runtime ~150MB)"
# instead of just dumping the raw process arglist.
describe_step() {
  case "$1" in
    *"snap install lxd"*)     printf 'installing LXD container runtime (~150MB snap)' ;;
    *"snap install"*)         printf 'installing snap package' ;;
    *"apt-get install"*"docker"*) printf 'installing Docker engine' ;;
    *"apt-get install"*"python3"*) printf 'installing Python 3 runtime' ;;
    *"apt-get install"*)      printf 'installing apt packages' ;;
    *"docker-compose"*)       printf 'configuring docker-compose plugin' ;;
    *"systemctl"*"docker"*)   printf 'starting Docker daemon' ;;
    *"usermod"*"docker"*)     printf 'granting ubuntu user docker access' ;;
    *)                        printf '%s' "$1" ;;
  esac
}

appliance_multipass_cmd() {
  if command -v multipass >/dev/null 2>&1; then
    printf 'multipass'
    return 0
  fi
  return 1
}

appliance_multipass_json() {
  local compose
  compose="$(appliance_multipass_cmd)"
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$compose" "$@" <<'PY'
import subprocess
import sys

cmd = sys.argv[1:]
try:
    proc = subprocess.run(cmd, capture_output=True, text=True, timeout=2)
except subprocess.TimeoutExpired:
    raise SystemExit(124)
sys.stdout.write(proc.stdout)
if proc.returncode != 0:
    raise SystemExit(proc.returncode)
PY
    return $?
  fi
  "$compose" "$@"
}

start_multipass_host() {
  case "$PARENT_OS" in
    darwin)
      if command -v open >/dev/null 2>&1; then
        open -gj -a Multipass >/dev/null 2>&1 || true
      fi
      ;;
    linux)
      if command -v systemctl >/dev/null 2>&1; then
        if [ "$(id -u)" -eq 0 ]; then
          systemctl start snap.multipass.multipassd >/dev/null 2>&1 || true
        elif command -v sudo >/dev/null 2>&1; then
          sudo systemctl start snap.multipass.multipassd >/dev/null 2>&1 || true
        fi
      fi
      if command -v snap >/dev/null 2>&1; then
        if [ "$(id -u)" -eq 0 ]; then
          snap start multipass >/dev/null 2>&1 || true
        elif command -v sudo >/dev/null 2>&1; then
          sudo snap start multipass >/dev/null 2>&1 || true
        fi
      fi
      ;;
  esac
}

appliance_multipass_ready() {
  local compose
  compose="$(appliance_multipass_cmd)"
  local max_wait="${CLOUD_LEARN_MULTIPASS_WAIT_SECONDS:-8}"
  local start_epoch
  start_epoch="$(date +%s)"
  local deadline=$((start_epoch + max_wait))
  while [ "$(date +%s)" -lt "$deadline" ]; do
    progress "==> Multipass: probing daemon/socket"
    if appliance_multipass_json list --format json >/dev/null 2>&1; then
      return 0
    fi
    if [ "$(date +%s)" -eq "$start_epoch" ]; then
      progress "==> Multipass: daemon/socket not reachable, attempting host auto-start"
      start_multipass_host
    fi
    sleep 3
    local elapsed
    elapsed=$(( $(date +%s) - start_epoch ))
    progress "==> Multipass: waiting for daemon/socket (${elapsed}s)"
  done
  return 1
}

appliance_instance_state() {
  local payload
  payload="$(appliance_multipass_json list --format json 2>/dev/null || true)"
  python3 - "$APPLIANCE_NAME" "$payload" <<'PY'
import json
import sys

name = sys.argv[1]
raw = sys.argv[2] if len(sys.argv) > 2 else ""
try:
    payload = json.loads(raw) if raw else {}
except Exception:
    print("")
    raise SystemExit(0)

def walk(node):
    if isinstance(node, dict):
        node_name = str(node.get("name") or "").strip()
        if node_name == name:
            state = str(node.get("state") or node.get("status") or "").strip().lower()
            print(state)
            raise SystemExit(0)
        for value in node.values():
            walk(value)
    elif isinstance(node, list):
        for item in node:
            walk(item)

walk(payload)
print("")
PY
}

appliance_instance_exists() {
  local payload
  payload="$(appliance_multipass_json list --format json 2>/dev/null || true)"
  python3 - "$APPLIANCE_NAME" "$payload" <<'PY'
import json
import sys

name = sys.argv[1]
raw = sys.argv[2] if len(sys.argv) > 2 else ""
try:
    payload = json.loads(raw) if raw else {}
except Exception:
    raise SystemExit(1)

def walk(node):
    if isinstance(node, dict):
        node_name = str(node.get("name") or "").strip()
        if node_name == name:
            raise SystemExit(0)
        for value in node.values():
            walk(value)
    elif isinstance(node, list):
        for item in node:
            walk(item)

walk(payload)
raise SystemExit(1)
PY
}

appliance_launch_vm() {
  local compose
  compose="$(appliance_multipass_cmd)"
  write_appliance_manifest
  write_appliance_host_sizing
  write_appliance_cloud_init
  if ! appliance_multipass_ready; then
    printf '%s\n' 'Multipass is installed, but the daemon/socket is not reachable. Open or restart Multipass on the host and retry.' >&2
    return 1
  fi
  progress "==> Appliance: checking VM state"
  local state
  state="$(appliance_instance_state)"
  if appliance_instance_exists; then
    progress "==> Appliance: existing VM detected (${state:-unknown})"
    case "$state" in
      running|Running)
        progress "    VM already running — reusing"
        ;;
      stopped|Stopped|suspended|Suspended)
        progress "==> Appliance: starting Multipass VM ${APPLIANCE_NAME}"
        "$compose" start "$APPLIANCE_NAME"
        ;;
      deleted|Deleted)
        # The VM was `multipass delete`d but not `purge`d — it's a
        # zombie. Trying to operate on it (mount, exec, transfer) will
        # silently fail or hang. Purge + relaunch is the only safe
        # path; otherwise the user just sees "could not transfer …" /
        # "waiting for cloud-init" forever.
        progress "==> Appliance: VM is in 'Deleted' (zombie) state — purging + relaunching"
        "$compose" purge >/dev/null 2>&1 || true
        progress "==> Appliance: launching fresh Multipass VM ${APPLIANCE_NAME}"
        progress "    (first launch needs to: download Ubuntu image ~600MB, install"
        progress "     LXD snap ~150MB, run cloud-init — total cold start 5-8 min)"
        "$compose" launch "$APPLIANCE_IMAGE" --name "$APPLIANCE_NAME" --cpus "$APPLIANCE_CPUS" --memory "$APPLIANCE_MEMORY" --disk "$APPLIANCE_DISK" --cloud-init "$APPLIANCE_DIR/cloud-init.yaml"
        ;;
      *)
        # Other states we don't know how to recover from automatically
        # (Starting / Restarting / Unknown). Print a clear pointer
        # instead of marching forward into "waiting for cloud-init"
        # against a VM that may never become usable.
        progress "==> Appliance: VM state '${state}' is not recoverable by the launcher."
        progress "    Run one of these and retry:"
        progress "      multipass info ${APPLIANCE_NAME}        # see what's wrong"
        progress "      multipass delete ${APPLIANCE_NAME} && multipass purge   # nuke + restart fresh"
        return 1
        ;;
    esac
  else
    progress "==> Appliance: launching Multipass VM ${APPLIANCE_NAME}"
    progress "    (first launch needs to: download Ubuntu image ~600MB, install"
    progress "     LXD snap ~150MB, run cloud-init — total cold start 5-8 min)"
    "$compose" launch "$APPLIANCE_IMAGE" --name "$APPLIANCE_NAME" --cpus "$APPLIANCE_CPUS" --memory "$APPLIANCE_MEMORY" --disk "$APPLIANCE_DISK" --cloud-init "$APPLIANCE_DIR/cloud-init.yaml"
  fi
  appliance_sync_workspace_into_vm
  appliance_sync_host_sizing_into_vm
  appliance_wait_for_cloud_init
}

appliance_wait_for_cloud_init() {
  # Poll cloud-init every 6s and surface concrete progress so the user
  # sees "[42s] Installing LXD container runtime (~150MB snap)" instead
  # of a silent "Waiting for initialization to complete" for 3-5 min.
  #
  # Cloud-init phases on a fresh Ubuntu 24.04 (timings for a typical
  # 8 GB / 4 vCPU VM on home broadband):
  #   init   — kernel / network / package mirrors    (~10s)
  #   config — apt update + base packages            (~30s)
  #   final  — runcmd: docker enable + snap lxd      (~120s)
  #
  # We track stage transitions, the current runcmd process, AND the
  # tail of cloud-init-output.log (in verbose mode) so triage is fast.
  local compose
  compose="$(appliance_multipass_cmd)"
  progress "==> Appliance: waiting for cloud-init (LXD snap install is the slow step)"
  local started_at last_status last_step elapsed heartbeat_at
  started_at=$(date +%s)
  last_step=""
  heartbeat_at=$started_at
  while true; do
    # cloud-init status: "not started" → "running" → "done" / "disabled"
    last_status=$("$compose" exec "$APPLIANCE_NAME" -- /bin/bash -lc \
      "cloud-init status 2>/dev/null | awk -F': ' '/^status:/{print \$2}' || echo unknown" 2>/dev/null \
      | tr -d '\r' | head -1)
    [ -z "$last_status" ] && last_status="unknown"
    elapsed=$(( $(date +%s) - started_at ))
    if [ "$last_status" = "done" ] || [ "$last_status" = "disabled" ]; then
      progress "    ✓ cloud-init finished (${elapsed}s)"
      break
    fi
    # Identify the slowest currently-running runcmd entry — that's the
    # bit the user actually wants to see described.
    local current_step current_desc
    current_step=$("$compose" exec "$APPLIANCE_NAME" -- /bin/bash -lc \
      "ps -eo args 2>/dev/null | grep -E 'snap install|apt-get install|docker' | grep -v grep | head -1 | cut -c1-100" 2>/dev/null \
      | tr -d '\r' | head -1 | sed 's/^[ \t]*//')
    if [ -n "$current_step" ]; then
      current_desc="$(describe_step "$current_step")"
      if [ "$current_desc" != "$last_step" ]; then
        progress "    [${elapsed}s] ${current_desc}"
        last_step="$current_desc"
      fi
    fi
    # Heartbeat every 30s so the user knows we're still alive even when
    # the runcmd identity hasn't changed (e.g. snap install lxd phase).
    if [ $(( $(date +%s) - heartbeat_at )) -ge 30 ] && [ -n "$last_step" ]; then
      progress "    [${elapsed}s] still ${last_step}…"
      heartbeat_at=$(date +%s)
    fi
    # Verbose mode: tail recent cloud-init log lines so the user sees
    # the raw apt / snap output.
    if [ "$VERBOSE" != "0" ]; then
      local tail_line
      tail_line=$("$compose" exec "$APPLIANCE_NAME" -- /bin/bash -lc \
        "sudo tail -1 /var/log/cloud-init-output.log 2>/dev/null" 2>/dev/null \
        | tr -d '\r' | head -1 | cut -c1-100)
      [ -n "$tail_line" ] && verbose "cloud-init-output.log: ${tail_line}"
    fi
    # Bail-out at 10 min — something has gone wrong by then.
    if [ "$elapsed" -gt 600 ]; then
      progress "    ⚠ cloud-init has been running >10 min — check"
      progress "      'multipass exec $APPLIANCE_NAME -- sudo tail -f /var/log/cloud-init-output.log'"
      break
    fi
    sleep 6
  done
}

appliance_exec_launcher() {
  # Deploy the inner compose stack DIRECTLY via docker compose — bypasses the
  # `cloud-learn up --detach` chain which aborted before building in some
  # environments (see memory: appliance-up-bridge-bug). Idempotent: docker
  # compose up -d only rebuilds changed services.
  local compose
  compose="$(appliance_multipass_cmd)"
  progress "==> Appliance: starting inner CloudLearn stack (direct compose)"
  progress "    (first run rebuilds the simulator image ~2-3 min; subsequent runs are cached)"
  # IMPORTANT: do NOT redirect inner output to /dev/null. The docker
  # build prints the layer-by-layer status that takes the longest;
  # showing it gives the user concrete feedback rather than a silent
  # 3-minute wait. In quiet (non-verbose) mode we still let the
  # progress lines flow because they're a real-time TTY for the user.
  "$compose" exec "$APPLIANCE_NAME" -- /bin/bash -lc "
    set -e
    # Bind-mounted into the simulator container at the same path; the
    # container runs as uid 100 (cloudlearn), so chown to match — without
    # this, EC2 launches PermissionError on workspace.mkdir().
    sudo mkdir -p /var/lib/cloudlearn/deployments
    sudo chown -R 100:101 /var/lib/cloudlearn/deployments
    cd ${APPLIANCE_WORKSPACE}
    # Ensure docker daemon is ready
    echo '    [inner] waiting for docker daemon…'
    for i in \$(seq 1 30); do
      if docker info >/dev/null 2>&1; then
        echo \"    [inner] docker daemon up after \${i}s\"
        break
      fi
      sleep 1
    done
    if ! docker info >/dev/null 2>&1; then
      echo 'docker daemon never became ready inside appliance VM' >&2
      exit 1
    fi
    # Build + start; -d (detach) so we return immediately; rebuilds changed only.
    echo '    [inner] docker compose up -d --build (output below):'
    docker compose -f docker-compose.appliance.yml up -d --build --remove-orphans 2>&1 \
      | sed 's/^/      /'
    echo '    [inner] container summary:'
    docker compose -f docker-compose.appliance.yml ps 2>&1 | sed 's/^/      /'
  "
}

appliance_health_check() {
  local compose
  compose="$(appliance_multipass_cmd)"
  local waited=0
  local max_wait="${CLOUD_LEARN_APPLIANCE_HEALTH_TIMEOUT:-180}"
  local last_bridge_ok=0 last_sim_ok=0 last_cloudsim_ok=0
  while [ "$waited" -lt "$max_wait" ]; do
    # Probe each component individually so we can show WHICH is missing.
    local bridge_ok sim_ok cloudsim_ok
    bridge_ok=$("$compose" exec "$APPLIANCE_NAME" -- /bin/bash -lc \
      "curl -fsS -o /dev/null -m 2 http://127.0.0.1:9171/health && echo 1 || echo 0" 2>/dev/null | tr -d '\r')
    sim_ok=$("$compose" exec "$APPLIANCE_NAME" -- /bin/bash -lc \
      "curl -fsS -o /dev/null -m 2 http://127.0.0.1:9000/healthz && echo 1 || echo 0" 2>/dev/null | tr -d '\r')
    cloudsim_ok=$("$compose" exec "$APPLIANCE_NAME" -- /bin/bash -lc \
      "curl -fsS -o /dev/null -m 2 http://127.0.0.1:9010/health && echo 1 || echo 0" 2>/dev/null | tr -d '\r')
    if [ "$bridge_ok" = "1" ] && [ "$sim_ok" = "1" ] && [ "$cloudsim_ok" = "1" ]; then
      progress "    ✓ runtime bridge, simulator, and CloudSim all healthy"
      return 0
    fi
    # Print a single composite status line every 6s so the user can see
    # which component is still missing.
    if [ $((waited % 6)) -eq 0 ]; then
      local status=""
      [ "$bridge_ok"   = "1" ] && status+=" bridge=✓" || status+=" bridge=…"
      [ "$sim_ok"      = "1" ] && status+="  sim=✓" || status+="  sim=…"
      [ "$cloudsim_ok" = "1" ] && status+="  cloudsim=✓" || status+="  cloudsim=…"
      progress "    [${waited}s/${max_wait}s] ${status}"
    fi
    last_bridge_ok=$bridge_ok
    last_sim_ok=$sim_ok
    last_cloudsim_ok=$cloudsim_ok
    sleep 2
    waited=$((waited + 2))
  done
  # Build a helpful diagnostic showing exactly which thing didn't start.
  local what_failed=""
  [ "$last_bridge_ok"   != "1" ] && what_failed+="\n    - runtime bridge (port 9171) — check: multipass exec $APPLIANCE_NAME -- sudo journalctl -u cloudlearn-runtime-bridge.service --no-pager -n 50"
  [ "$last_sim_ok"      != "1" ] && what_failed+="\n    - simulator (port 9000) — check: multipass exec $APPLIANCE_NAME -- docker logs cloud-learn-simulator-1 --tail 80"
  [ "$last_cloudsim_ok" != "1" ] && what_failed+="\n    - CloudSim (port 9010) — check: multipass exec $APPLIANCE_NAME -- docker logs cloud-learn-cloudsim-1 --tail 80"
  _die "health check timed out after ${max_wait}s — the following components are not responding:${what_failed}" \
"Inspect the docker compose logs:
  multipass exec $APPLIANCE_NAME -- docker compose -f ${APPLIANCE_WORKSPACE}/docker-compose.appliance.yml logs --tail 100
Check port conflicts:
  multipass exec $APPLIANCE_NAME -- ss -tlnp
Restart fresh:
  cloud-learn down && cloud-learn up -v"
}

# Print the URL banner at the very end of a successful `cloud-learn up`.
print_url_banner() {
  local vm_ip
  vm_ip="$(multipass info "$APPLIANCE_NAME" --format=csv 2>/dev/null | awk -F, 'NR==2 {print $3}' | head -1)"
  [ -z "$vm_ip" ] && vm_ip="<vm-ip>"
  launch_success_banner "http://${vm_ip}:9000/"
}

vyomi_host_ssh_bootstrap() {
  # Generate ~/.ssh/vyomi_ed25519 + mirror pubkey to
  # ~/.config/vyomi/host-ssh-pubkey.pub if not already present.
  # Subsequently mounted into the appliance VM and used as the
  # authorized_keys source for every new container the simulator
  # launches. Idempotent — never overwrites existing keys.
  local script="${ROOT_DIR}/scripts/vyomi-host-ssh-bootstrap.sh"
  if [ ! -x "$script" ]; then
    progress "vyomi-host-ssh-bootstrap.sh not executable or missing — skipping"
    return 0
  fi
  progress "==> Vyomi host SSH bootstrap"
  bash "$script" || progress "host SSH bootstrap returned non-zero — Connect via SSH may need manual key install"
}

vyomi_mount_host_pubkey_into_appliance() {
  # Push the host's public key into the appliance VM at
  # /etc/vyomi/host-ssh-pubkey.pub, which docker-compose bind-mounts
  # into the simulator container at /config/host-ssh-pubkey.pub.
  # core/vm_connect.py reads it on every Connect-info request and
  # injects it into the target LXD container's authorized_keys —
  # so the user never sees a 'download key + chmod' step.
  local compose
  compose="$(appliance_multipass_cmd 2>/dev/null || echo multipass)"
  local pubkey="${HOME}/.config/vyomi/host-ssh-pubkey.pub"
  if [ ! -f "$pubkey" ]; then
    progress "no host pubkey at $pubkey — skipping mount"
    return 0
  fi
  progress "==> Pushing host pubkey into appliance VM"
  "$compose" transfer "$pubkey" "${APPLIANCE_NAME}:/tmp/vyomi-host-ssh-pubkey.pub" >/dev/null 2>&1 || true
  "$compose" exec "$APPLIANCE_NAME" -- sudo bash -lc '
    set -e
    install -d -m 755 /etc/vyomi
    install -m 644 /tmp/vyomi-host-ssh-pubkey.pub /etc/vyomi/host-ssh-pubkey.pub
    rm -f /tmp/vyomi-host-ssh-pubkey.pub
  ' >/dev/null 2>&1 || progress "host pubkey push failed (non-fatal) — Connect will fall back to per-instance keys"
}

appliance_start_runtime_bridge() {
  local compose
  compose="$(appliance_multipass_cmd)"
  # Copy the bridge script into a VM-local path INSTEAD of pointing the
  # systemd unit at the SSHFS-mounted workspace.
  #
  # Background: on macOS brew installs ROOT_DIR is /opt/homebrew/Cellar/
  # cloud-learn/<v>/libexec, which sits behind the brew-prefix sandbox.
  # Multipass's SSHFS workspace mount cannot read THROUGH that sandbox
  # from inside the VM — every file under /workspace/cloud-learn shows
  # as "Permission denied", even to root. So a systemd ExecStart
  # pointing at /workspace/cloud-learn/core/runtime_bridge.py fails
  # immediately with Python exit 2 ("can't open file").
  #
  # We resolve this by transferring the source script INTO the VM at
  # a writable, brew-sandbox-free path (/var/lib/cloudlearn/), then
  # pointing systemd at THAT path. The mount can stay or go — the
  # bridge daemon doesn't care anymore.
  local bridge_src="${ROOT_DIR}/core/runtime_bridge.py"
  local bridge_dst="/var/lib/cloudlearn/runtime_bridge.py"
  if [ ! -f "$bridge_src" ]; then
    _die "runtime bridge source not found at $bridge_src" \
"This usually means the brew bundle is corrupt. Try:
  brew reinstall cloud-learn
Or run from a workspace clone instead:
  CLOUD_LEARN_HOME=/path/to/cloud-learn cloud-learn up"
  fi
  verbose "transferring $bridge_src → $APPLIANCE_NAME:$bridge_dst"
  # Push the script through the multipass channel (avoids SSHFS) and
  # install it into /var/lib/cloudlearn/ owned by root with mode 644.
  if ! "$compose" transfer "$bridge_src" "${APPLIANCE_NAME}:/tmp/runtime_bridge.py" 2>/dev/null; then
    _die "multipass transfer failed pushing runtime_bridge.py into VM" \
"This usually means the VM is not in 'Running' state. Check:
  multipass info $APPLIANCE_NAME
If state is anything other than 'Running', recover with:
  cloud-learn down && cloud-learn up"
  fi
  # Write the systemd unit, enable+start, then poll health. Capture the
  # FULL stderr stream so on failure we can surface the real reason.
  local install_log
  install_log="$(mktemp -t cloud-learn-bridge-XXXXXX.log)"
  # Bridge poll timeout: bumped 30s → 180s. On a fresh cold-start the
  # snap.lxd.daemon.service can take 1-2 min to settle, and systemd
  # was queueing our bridge start behind it. Even though we drop the
  # LXD After= dependency below, a generous timeout keeps things
  # robust across slow first-boot conditions.
  # NOTE on the inner script structure: multipass exec under `set -e`
  # has a quirk where explicit `exit 0` from a child returns rc=1 to
  # the parent. The script therefore signals success by FALLING THROUGH
  # past the for-loop (break out, don't exit 0). Failure still uses
  # `exit 1` which propagates fine.
  if ! "$compose" exec "$APPLIANCE_NAME" -- /bin/bash -lc "set -e
    sudo mkdir -p /var/lib/cloudlearn
    sudo install -m 644 /tmp/runtime_bridge.py $bridge_dst
    rm -f /tmp/runtime_bridge.py
    sudo tee /etc/systemd/system/cloudlearn-runtime-bridge.service >/dev/null <<UNIT
[Unit]
Description=CloudLearn runtime bridge (LXD/multipass over HTTP for the simulator)
# Only require network — the bridge can come up before docker/LXD are
# ready, and they're checked on-demand per HTTP request anyway.
# Earlier After=snap.lxd.daemon.service caused 1-3 min start delays
# while LXD finished initialising, well past our health-poll budget.
After=network.target
Wants=docker.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 $bridge_dst --host 0.0.0.0 --port 9171
Restart=on-failure
RestartSec=5
User=root
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
UNIT
    sudo systemctl daemon-reload
    # daemon-reload picks up the new dependency graph; reset-failed
    # clears any prior 'failed' state from earlier launches.
    sudo systemctl reset-failed cloudlearn-runtime-bridge.service >/dev/null 2>&1 || true
    sudo systemctl enable --now cloudlearn-runtime-bridge.service >/dev/null 2>&1
    READY=0
    for i in \$(seq 1 180); do
      if curl -fsS http://127.0.0.1:9171/health >/dev/null 2>&1; then
        echo READY-after-\${i}s
        READY=1
        break
      fi
      # Heartbeat every 15s so triage shows it's polling, not hung.
      if [ \$((i % 15)) -eq 0 ]; then
        echo \"  polling /health … \${i}s elapsed; systemctl says: \$(sudo systemctl is-active cloudlearn-runtime-bridge.service 2>&1 | head -1)\"
      fi
      sleep 1
    done
    if [ \"\$READY\" = \"0\" ]; then
      echo NOT_READY
      echo '--- systemctl status ---'
      sudo systemctl status cloudlearn-runtime-bridge.service --no-pager 2>&1 | head -20 || true
      echo '--- journalctl ---'
      sudo journalctl -u cloudlearn-runtime-bridge.service --no-pager -n 40 2>&1 || true
      exit 1
    fi
    # Fall through — natural script end → bash exits 0 → multipass
    # exec correctly propagates 0 to the caller." > "$install_log" 2>&1; then
    # Surface the captured failure into the user's terminal AND the log.
    local last_lines
    last_lines="$(tail -25 "$install_log" | sed 's/^/      /')"
    progress "    Bridge install output (tail -25):"
    while IFS= read -r line; do _emit "$line"; done <<<"$last_lines"
    cat "$install_log" >> "$_LOG_FILE" 2>/dev/null || true
    rm -f "$install_log"
    _die "cloudlearn-runtime-bridge.service failed to become healthy on :9171 (180s timeout)" \
"The simulator's lxd_available check will return False without this.
Inspect the VM directly:
  multipass exec $APPLIANCE_NAME -- sudo systemctl status cloudlearn-runtime-bridge.service
  multipass exec $APPLIANCE_NAME -- sudo journalctl -u cloudlearn-runtime-bridge.service --no-pager -n 80
Then re-run with verbose:
  cloud-learn up -v"
  fi
  cat "$install_log" >> "$_LOG_FILE" 2>/dev/null || true
  verbose "bridge install output:"
  if [ "$VERBOSE" != "0" ]; then sed 's/^/  /' "$install_log" >&2; fi
  rm -f "$install_log"
}

wait_for_inner_compose() {
  local waited=0
  local max_wait="${CLOUD_LEARN_INNER_COMPOSE_WAIT_SECONDS:-180}"
  while [ "$waited" -lt "$max_wait" ]; do
    if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
      return 0
    fi
    if command -v docker-compose >/dev/null 2>&1 && docker-compose version >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
    waited=$((waited + 2))
  done
  printf '%s\n' 'docker compose is not available inside the appliance VM yet' >&2
  return 1
}

compose_cmd() {
  if command -v docker >/dev/null 2>&1; then
    if docker compose version >/dev/null 2>&1; then
      printf 'docker compose'
      return 0
    fi
  fi
  if command -v docker-compose >/dev/null 2>&1; then
    printf 'docker-compose'
    return 0
  fi
  return 1
}

compose_backend_available() {
  if command -v docker >/dev/null 2>&1; then
    if docker info >/dev/null 2>&1; then
      return 0
    fi
  fi
  return 1
}

install_compose() {
  local system="${1:-$(uname -s)}"
  case "$system" in
    Darwin)
      if command -v brew >/dev/null 2>&1; then
        printf '%s\n' 'installing docker-compose via Homebrew...' >&2
        brew install docker-compose
        return 0
      fi
      ;;
    Linux)
      if command -v apt-get >/dev/null 2>&1; then
        printf '%s\n' 'installing docker compose via apt...' >&2
        if command -v sudo >/dev/null 2>&1; then
          sudo apt-get update
          if sudo apt-get install -y docker-compose-plugin >/dev/null 2>&1; then
            return 0
          fi
          sudo apt-get install -y docker-compose
          return 0
        fi
      fi
      if command -v dnf >/dev/null 2>&1; then
        printf '%s\n' 'installing docker compose via dnf...' >&2
        if command -v sudo >/dev/null 2>&1; then
          sudo dnf install -y docker-compose || sudo dnf install -y docker-compose-plugin
          return 0
        fi
      fi
      if command -v yum >/dev/null 2>&1; then
        printf '%s\n' 'installing docker compose via yum...' >&2
        if command -v sudo >/dev/null 2>&1; then
          sudo yum install -y docker-compose || sudo yum install -y docker-compose-plugin
          return 0
        fi
      fi
      ;;
  esac
  return 1
}

ensure_prereqs() {
  if [ "$RUNTIME_CONTEXT" = "inner" ]; then
    wait_for_inner_compose
    local missing=0
    if ! command -v docker >/dev/null 2>&1; then
      printf '%s\n' 'docker is not installed or not on PATH' >&2
      missing=1
    fi
    if ! compose_cmd >/dev/null 2>&1; then
      printf '%s\n' 'docker compose is not available' >&2
      missing=1
    fi
    if [ ! -f "$COMPOSE_FILE" ]; then
      printf 'compose file not found: %s\n' "$COMPOSE_FILE" >&2
      missing=1
    fi
    return "$missing"
  fi

  if ! command -v multipass >/dev/null 2>&1; then
    printf '%s\n' 'multipass is not installed or not on PATH' >&2
    return 1
  fi
  return 0
}

doctor() {
  printf 'cloud-learn root: %s\n' "$ROOT_DIR"
  printf 'compose file: %s\n' "$COMPOSE_FILE"
  printf 'runtime context: %s\n' "$RUNTIME_CONTEXT"
  if [ "$RUNTIME_CONTEXT" = "inner" ]; then
    if command -v docker >/dev/null 2>&1; then
      printf 'docker: available\n'
    else
      printf 'docker: missing\n'
    fi
    if compose_cmd >/dev/null 2>&1; then
      printf 'compose: available\n'
    else
      printf 'compose: missing\n'
    fi
    if compose_backend_available; then
      printf 'engine: reachable\n'
    else
      printf 'engine: unreachable\n'
    fi
    printf 'mode: appliance inner stack\n'
  else
    if command -v multipass >/dev/null 2>&1; then
      printf 'multipass: available\n'
    else
      printf 'multipass: missing\n'
    fi
    printf 'mode: appliance launcher\n'
  fi
  printf 'distribution mode: %s\n' "$CLOUDLEARN_DISTRIBUTION_MODE"
}

run_compose() {
  local cmd="$1"
  shift || true
  local compose
  compose="$(compose_cmd)"
  # shellcheck disable=SC2086
  $compose --project-name "$PROJECT_NAME" --project-directory "$ROOT_DIR" -f "$COMPOSE_FILE" "$cmd" "$@"
}

run_compose_for_project() {
  local project_name="$1"
  shift
  local cmd="$1"
  shift || true
  local compose
  compose="$(compose_cmd)"
  # shellcheck disable=SC2086
  $compose --project-name "$project_name" --project-directory "$ROOT_DIR" -f "$COMPOSE_FILE" "$cmd" "$@"
}

cleanup_legacy_projects() {
  local legacy_projects=("cloudlearn")
  local legacy
  for legacy in "${legacy_projects[@]}"; do
    if [ "$legacy" != "$PROJECT_NAME" ]; then
      run_compose_for_project "$legacy" down --remove-orphans >/dev/null 2>&1 || true
    fi
  done
}

inner_run() {
  local subcmd="${1:-help}"
  if [ "$#" -gt 0 ]; then
    shift
  fi
  case "$subcmd" in
    up)
      ensure_prereqs
      run_compose up --build --force-recreate "$@"
      ;;
    down)
      ensure_prereqs
      run_compose down "$@"
      ;;
    restart)
      ensure_prereqs
      run_compose restart "$@"
      ;;
    status|ps)
      ensure_prereqs
      run_compose ps "$@"
      ;;
    build)
      ensure_prereqs
      run_compose build "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      printf 'Unknown inner command: %s\n\n' "$subcmd" >&2
      usage >&2
      exit 2
      ;;
  esac
}

outer_run() {
  local subcmd="${1:-help}"
  if [ "$#" -gt 0 ]; then
    shift
  fi
  # Parse global flags (positional after subcmd). Right now just -v.
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -v|--verbose)
        VERBOSE=1
        export CLOUD_LEARN_VERBOSE=1
        shift
        ;;
      *)
        break
        ;;
    esac
  done
  case "$subcmd" in
    up)
      [ "$VERBOSE" != "0" ] && progress "==> Verbose mode on (CLOUD_LEARN_VERBOSE=1)"
      progress "==> Logging to ${_LOG_FILE}"
      phase "Pre-flight checks (multipass / docker available)"
      ensure_prereqs
      phase_done
      phase "Host SSH identity bootstrap"
      vyomi_host_ssh_bootstrap
      phase_done
      phase "Appliance manifest + cloud-init generation"
      write_appliance_manifest
      phase_done
      phase "Launching appliance VM (cold start: 3-5 min downloading image + LXD snap)"
      appliance_launch_vm
      phase_done
      phase "Pushing host SSH pubkey into appliance"
      vyomi_mount_host_pubkey_into_appliance
      phase_done
      phase "Installing runtime bridge (systemd unit on appliance VM)"
      appliance_start_runtime_bridge
      phase_done
      phase "Building + starting CloudLearn stack inside appliance (2-3 min on first run)"
      appliance_exec_launcher
      phase_done
      phase "Waiting for simulator, CloudSim, and runtime bridge to become healthy"
      appliance_health_check
      phase_done
      print_url_banner
      ;;
    down|stop)
      ensure_prereqs
      if command -v multipass >/dev/null 2>&1; then
        multipass stop "$APPLIANCE_NAME" >/dev/null 2>&1 || true
      fi
      ;;
    force-stop|kill)
      ensure_prereqs
      if command -v multipass >/dev/null 2>&1; then
        multipass stop --force "$APPLIANCE_NAME" >/dev/null 2>&1 || true
      fi
      ;;
    restart)
      ensure_prereqs
      if command -v multipass >/dev/null 2>&1; then
        multipass restart "$APPLIANCE_NAME" >/dev/null 2>&1 || true
      fi
      appliance_start_runtime_bridge
      appliance_exec_launcher
      appliance_health_check
      ;;
    status|ps)
      ensure_prereqs
      if command -v multipass >/dev/null 2>&1; then
        multipass info "$APPLIANCE_NAME" || true
      fi
      ;;
    doctor)
      doctor
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      printf 'Unknown command: %s\n\n' "$subcmd" >&2
      usage >&2
      exit 2
      ;;
  esac
}

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

if [ "$RUNTIME_CONTEXT" = "inner" ]; then
  inner_run "$cmd" "$@"
else
  outer_run "$cmd" "$@"
fi
